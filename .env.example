# Resend — used by the waitlist signup server action.
# Get an API key at https://resend.com and create an Audience for signups.
# Copy this file to .env.local and fill in the values (never commit .env.local).
RESEND_API_KEY=
RESEND_AUDIENCE_ID=

# Signup notifications — email the team on each new signup. Leave WAITLIST_NOTIFY_TO
# empty to disable. WAITLIST_NOTIFY_FROM must be an address on a domain verified in
# Resend; if empty it falls back to onboarding@resend.dev (only delivers to the
# Resend account owner's address — fine for a personal heads-up, not for a team).
WAITLIST_NOTIFY_TO=
WAITLIST_NOTIFY_FROM=

# Vemetric — product analytics (https://vemetric.com).
# This is a public client-side token, hence the NEXT_PUBLIC_ prefix.
NEXT_PUBLIC_VEMETRIC_TOKEN=
