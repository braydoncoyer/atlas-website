# Resend — used by the waitlist signup server action.
# Get an API key at https://resend.com and create an Audience for signups.
# Copy this file to .env.local and fill in the values (never commit .env.local).
RESEND_API_KEY=
RESEND_AUDIENCE_ID=

# Vemetric — product analytics (https://vemetric.com).
# This is a public client-side token, hence the NEXT_PUBLIC_ prefix.
NEXT_PUBLIC_VEMETRIC_TOKEN=
